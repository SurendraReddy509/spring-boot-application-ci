# -----------------------------
# Sensitive files
# -----------------------------
**/*.pem
**/*.key
**/*.crt
**/*.csv

# -----------------------------
# OS files
# -----------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------
# Node
# -----------------------------
**/node_modules/

# -----------------------------
# Python
# -----------------------------
**/venv/
**/.venv/
__pycache__/
*.pyc

# -----------------------------
# Java / Spring Boot
# -----------------------------
**/target/
**/build/
**/.gradle/
*.class

# ✅ IMPORTANT: allow JAR for Docker build (relative to context)
!target/
!target/*.jar

# -----------------------------
# Logs
# -----------------------------
**/*.log

# -----------------------------
# Environment files
# -----------------------------
*.env
*.env.*

# -----------------------------
# IDE files
# -----------------------------
**/.vscode/
**/.idea/

# -----------------------------
# Misc binaries
# -----------------------------
*.o
*.so
*.dll
*.exe